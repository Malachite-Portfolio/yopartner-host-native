{
  "expo": {
    "name": "YoPartner",
    "slug": "yopartner-host-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/yopartner-logo.png",
    "userInterfaceStyle": "light",
    "scheme": "yopartnerhost",
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-firebase/messaging",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow YoPartner Host to access your camera for live verification.",
          "microphonePermission": "Allow YoPartner Host to access your microphone for live verification.",
          "recordAudioAndroid": true,
          "barcodeScannerEnabled": false
        }
      ],
      "expo-secure-store",
      "expo-notifications"
    ],
    "splash": {
      "image": "./assets/yopartner-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#fffdf8"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.yopartner.host",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "POST_NOTIFICATIONS",
        "USE_FULL_SCREEN_INTENT",
        "WAKE_LOCK"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#fffdf8",
        "foregroundImage": "./assets/yopartner-logo.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "fa643584-ddad-45af-993d-6a21eb2b3765"
      }
    },
    "owner": "yo-partner"
  }
}
